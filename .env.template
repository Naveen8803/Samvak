# ============================================================
# Samvak — Environment Variables
# Copy this file to .env and fill in your values.
# Load with:  python-dotenv  or  set manually before running.
# ============================================================

# ── Flask core ──────────────────────────────────────────────
SECRET_KEY=change_me_to_a_long_random_string

# ── Gemini API (required for ISL gloss conversion) ──────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Real-time translation pipeline ─────────────────────────
# Controls which backend runs first when a sequence arrives.
# Options: translation_first | hf_first
HYBRID_SEQUENCE_PRIORITY=translation_first

# ── Optional: HF Sequence model (extra sign recogniser) ─────
# Leave blank to use only the local LSTM + iSign retrieval.
HF_SEQUENCE_REPO_ID=
HF_SEQUENCE_MODEL_FILE=
HF_SEQUENCE_LABELS_FILE=
HF_SEQUENCE_MEAN_FILE=
HF_SEQUENCE_STD_FILE=
HF_SEQUENCE_MIN_CONFIDENCE=0.65
HF_SEQUENCE_LENGTH=30
HF_SEQUENCE_FEATURE_SIZE=258

# ── Optional: HF Image model (per-frame classifier) ─────────
HF_IMAGE_REPO_ID=
HF_IMAGE_MODEL_FILE=
HF_IMAGE_LABELS_FILE=
HF_IMAGE_MIN_CONFIDENCE=0.75
HF_IMAGE_INPUT_SIZE=224

# ── iSign retrieval index ───────────────────────────────────
ISIGN_RETRIEVAL_INDEX_PATH=model_data/isign_retrieval_index.npz
ISIGN_RETRIEVAL_META_PATH=model_data/isign_retrieval_meta.json
ISIGN_RETRIEVAL_MIN_CONFIDENCE=0.82
ISIGN_RETRIEVAL_TENTATIVE_CONFIDENCE=0.70
ISIGN_RETRIEVAL_MARGIN=0.035

# ── Fingerspell router (disabled by default) ─────────────────
FINGERSPELL_ROUTER_ENABLED=0
FINGERSPELL_MIN_CONFIDENCE=0.65

# ── Cookie security (set to 1 in production with HTTPS) ─────
FLASK_SECURE_COOKIE=0

# ── Model versioning (informational labels only) ─────────────
MODEL_VERSION=posehands-tcn-v1
CLASS_SET_VERSION=prod-40-v1
THRESHOLD_VERSION=prod-40-v1
